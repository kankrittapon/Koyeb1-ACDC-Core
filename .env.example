PORT=8001
NODE_ENV=development
APP_TIMEZONE=Asia/Bangkok
INTERNAL_API_KEY=change-this
JWT_SECRET=replace-with-a-long-secret
# Optional direct Postgres connection string if you decide to use DB URL access later
# Format:
# postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Supabase1 project URL and service role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
LINE_CHANNEL_ACCESS_TOKEN=replace-me
LINE_CHANNEL_SECRET=replace-me
ENABLE_LINE_WEBHOOK=false
ENABLE_SCHEDULER=false
KOYEB0_BASE_URL=http://100.68.88.63:18080
KOYEB0_INTERNAL_API_KEY=change-this
KOYEB0_DEFAULT_POLICY=private_first
CORS_ALLOW_ORIGINS=*
PUBLIC_BASE_URL=https://your-koyeb1-service.example.com
NEXTJS_FRONTEND_URL=https://your-frontend.vercel.app
GOOGLE_DRIVE_CLIENT_ID=replace-me
GOOGLE_DRIVE_CLIENT_SECRET=replace-me
GOOGLE_DRIVE_REFRESH_TOKEN=replace-me
# Legacy compatibility from old system is also supported:
# GDRIVE_CLIENT_ID=
# GDRIVE_CLIENT_SECRET=
# GDRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER=replace-me
GOOGLE_DRIVE_IMAGE_FOLDER=
GOOGLE_DRIVE_FILE_FOLDER=
GOOGLE_DRIVE_DOC_FOLDER=
GOOGLE_DRIVE_PDF_FOLDER=
